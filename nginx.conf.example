##############################################
# NGINX – Portfolio Security Config Example
# Copy this server block into your nginx.conf
# or sites-available/boing.dev
##############################################

server {
    listen 80;
    server_name boing.dev www.boing.dev;
    # Redirect all HTTP to HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name boing.dev www.boing.dev;

    # SSL (update paths for your certificates)
    ssl_certificate     /etc/letsencrypt/live/boing.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/boing.dev/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    root /var/www/portfolio/dist;
    index index.html;

    # React Router – serve index.html for all routes
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Long-lived cache for hashed assets
    location /assets/ {
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # No caching for the HTML entry point
    location = /index.html {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    # ── Security Headers ──────────────────────────────────────
    add_header Content-Security-Policy
        "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob:; connect-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests;"
        always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" always;
}
